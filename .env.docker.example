# Copy to .env.docker before running docker compose
# cp .env.docker.example .env.docker
#
# Optional host override when you already have PostgreSQL running on 5432:
# GITPINS_DB_PORT=5433 docker compose up -d

# Local app URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# GitHub App for localhost (gitpins-local)
GITHUB_APP_SLUG=gitpinslocal
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Security secrets
JWT_SECRET=
ENCRYPTION_SECRET=

# Optional fallback only during migration to admin allowlist

# Local DB (inside docker compose network)
DATABASE_URL=postgresql://gitpins:gitpins@db:5432/gitpins_local_clone
DIRECT_URL=postgresql://gitpins:gitpins@db:5432/gitpins_local_clone

# Safety: do not mutate GitHub from local by default
GITPINS_DISABLE_GITHUB_MUTATIONS=true
